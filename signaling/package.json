{
  "name": "syncscript-signaling",
  "version": "1.0.0",
  "description": "Room-based signaling server for SyncScript",
  "main": "dist/server.js",
  "scripts": {
    "start": "ts-node src/server.ts",
    "dev": "nodemon --watch src/**/*.ts --exec ts-node src/server.ts",
    "build": "tsc"
  },
  "dependencies": {
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}