{
  "name": "syncscript-signaling",
  "version": "1.0.0",
  "description": "Room-based signaling server for SyncScript",
  "main": "dist/server.js",
  "scripts": {
    "start": "ts-node src/server.ts",
    "start:prod": "node dist/server.js",
    "dev": "nodemon --watch src/**/*.ts --exec ts-node src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "mock:client": "ts-node src/scripts/mockClient.ts"
  },
  "dependencies": {
    "ioredis": "^5.4.1",
    "prom-client": "^15.1.3",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "winston": "^3.17.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "eslint": "^9.25.0",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
