signaling/dist/
*.tsbuildinfo

# --- Extension Specific ---
*.vsix
.vscode-test/

# --- Signaling Server Data ---
# We ignore the actual data so you don't push private room info to GitHub
signaling/data/rooms.json

# --- Environment Secrets ---
.env
.env.local