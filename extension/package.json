{
  "name": "syncscript",
  "displayName": "SyncScript P2P",
  "description": "Real-time room-based code synchronization",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "syncscript-explorer",
          "title": "SyncScript",
          "icon": "$(broadcast)"
        }
      ]
    },
    "views": {
      "syncscript-explorer": [
        {
          "type": "webview",
          "id": "syncscript.sidebar",
          "name": "Workspace Control"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run tailwind:build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "tailwind:build": "tailwindcss -i ./webview/style.css -o ./webview/output.css",
    "tailwind:watch": "tailwindcss -i ./webview/style.css -o ./webview/output.css --watch"
  },
  "devDependencies": {
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "autoprefixer": "^10.4.17",
    "diff-match-patch": "^1.0.5",
    "postcss": "^8.4.35",
    "ws": "^8.16.0"
  }
}
