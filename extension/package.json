{
  "name": "syncscript",
  "displayName": "SyncScript P2P",
  "description": "Real-time room-based code synchronization",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/Migz-apps/SyncScript2.0.git"
  },
  "files": [
    "out/**/*",
    "webview/**/*",
    "package.json",
    "tailwind.config.js"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "SyncScript",
      "properties": {
        "syncscript.signalingUrl": {
          "type": "string",
          "default": "ws://localhost:4444",
          "description": "WebSocket URL for the SyncScript signaling server."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "syncscript-explorer",
          "title": "SyncScript",
          "icon": "$(broadcast)"
        }
      ]
    },
    "views": {
      "syncscript-explorer": [
        {
          "type": "webview",
          "id": "syncscript.sidebar",
          "name": "Workspace Control"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run tailwind:build",
    "compile": "tsc -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "lint": "eslint src --ext .ts",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package:vsix": "vsce package --no-dependencies --out ../artifacts/syncscript.vsix",
    "tailwind:build": "tailwindcss -i ./webview/style.css -o ./webview/output.css",
    "tailwind:watch": "tailwindcss -i ./webview/style.css -o ./webview/output.css --watch"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "eslint": "^9.25.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "autoprefixer": "^10.4.17",
    "diff-match-patch": "^1.0.5",
    "postcss": "^8.4.35",
    "ws": "^8.16.0"
  }
}
