{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Server",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/signaling",
      "command": "npm.cmd run dev"
    },
    {
      "name": "SyncScript Client 1",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "--user-data-dir=${workspaceFolder}/.vscode/client-a",
        "--new-window",
        "${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/extension/out/**/*.js"]
    },
    {
      "name": "SyncScript Client 2",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "--user-data-dir=${workspaceFolder}/.vscode/client-b",
        "--new-window",
        "${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/extension/out/**/*.js"]
    }
  ],
  "compounds": [
    {
      "name": "🚀 Full SyncScript Launch",
      "preLaunchTask": "build-extension",
      "configurations": [
        "Run Server",
        "SyncScript Client 1",
        "SyncScript Client 2"
      ],
      "stopAll": true
    }
  ]
}
