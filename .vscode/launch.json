{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Signaling Server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/signaling",
      "program": "server.js",
      "runtimeExecutable": "nodemon",
      "restart": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Peer A (Primary)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "--user-data-dir=${workspaceFolder}/.vscode-test-peer-a",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/extension/out/**/*.js"
      ]
    },
    {
      "name": "Peer B (Secondary)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "--user-data-dir=${workspaceFolder}/.vscode-test-peer-b",
        "${workspaceFolder}/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/extension/out/**/*.js"
      ]
    }
  ],
  "compounds": [
    {
      "name": "🚀 Launch SyncScript Ecosystem",
      "configurations": [
        "Signaling Server",
        "Peer A (Primary)",
        "Peer B (Secondary)"
      ],
      "stopAll": true,
      "presentation": {
        "group": "sync",
        "order": 1
      }
    }
  ]
}