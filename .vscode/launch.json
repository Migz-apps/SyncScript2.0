{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/signaling",
      "program": "${workspaceFolder}/signaling/src/server.ts",
      "console": "integratedTerminal"
    },
    {
      "name": "SyncScript (VS Code Window)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "preLaunchTask": "watch-extension",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "--user-data-dir=${workspaceFolder}/.vscode/client-vscode"
      ],
      "outFiles": [
        "${workspaceFolder}/extension/out/**/*.js"
      ]
    },
    {
      "name": "SyncScript (Cursor Window)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "cursor",
      "preLaunchTask": "watch-extension",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "--user-data-dir=${workspaceFolder}/.vscode/client-cursor"
      ],
      "outFiles": [
        "${workspaceFolder}/extension/out/**/*.js"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Debug SyncScript (VS Code + Cursor)",
      "configurations": [
        "SyncScript (VS Code Window)",
        "SyncScript (Cursor Window)"
      ],
      "stopAll": true
    }
  ]
}