{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Signaling Server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/signaling",
      "program": "server.js",
      "runtimeExecutable": "nodemon",
      "restart": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Run Extension (Peer A)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/extension/out/**/*.js"
      ]
    },
    {
      "name": "Run Extension (Peer B)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "--user-data-dir=${workspaceFolder}/.vscode-test-peer-b"
      ],
      "outFiles": [
        "${workspaceFolder}/extension/out/**/*.js"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Full SyncScript Launch",
      "configurations": [
        "Signaling Server",
        "Run Extension (Peer A)",
        "Run Extension (Peer B)"
      ]
    }
  ]
}