{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-extension",
      "type": "shell",
      "command": "npm.cmd run compile",
      "options": {
        "cwd": "${workspaceFolder}/extension"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "watch-extension",
      "type": "shell",
      "command": "npm.cmd run watch",
      "options": {
        "cwd": "${workspaceFolder}/extension"
      },
      "isBackground": true,
      "problemMatcher": "$tsc-watch"
    },
    {
      "label": "run-server",
      "type": "shell",
      "command": "npm.cmd run dev",
      "options": {
        "cwd": "${workspaceFolder}/signaling"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*starting.*",
          "endsPattern": ".*started.*|.*listening.*"
        },
        "pattern": {
          "regexp": "^.*$"
        }
      }
    }
  ]
}
